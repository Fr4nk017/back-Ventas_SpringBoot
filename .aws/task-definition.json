{
  "family": "ventas-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::__ACCOUNT_ID__:role/LabRole",
  "taskRoleArn": "arn:aws:iam::__ACCOUNT_ID__:role/LabRole",
  "containerDefinitions": [
    {
      "name": "ventas-backend",
      "image": "__IMAGE__",
      "essential": true,
      "portMappings": [
        { "containerPort": 8080, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "DB_NAME", "value": "ventasdb" }
      ],
      "secrets": [
        { "name": "DB_ENDPOINT", "valueFrom": "arn:aws:ssm:__REGION__:__ACCOUNT_ID__:parameter/innovatech/db_endpoint" },
        { "name": "DB_PORT", "valueFrom": "arn:aws:ssm:__REGION__:__ACCOUNT_ID__:parameter/innovatech/db_port" },
        { "name": "DB_USERNAME", "valueFrom": "arn:aws:ssm:__REGION__:__ACCOUNT_ID__:parameter/innovatech/db_username" },
        { "name": "DB_PASSWORD", "valueFrom": "arn:aws:ssm:__REGION__:__ACCOUNT_ID__:parameter/innovatech/db_password" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ventas-backend",
          "awslogs-region": "__REGION__",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
